{
  "hosting": {
    "target": "fontastic",
    "public": "public",
    "cleanUrls": true,
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "headers": [
      {
        "source": "**/*.@(jpg|jpeg|png|webp|svg|woff2)",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "max-age=31536000, immutable"
          }
        ]
      },
      {
        "source": "**/*.@(js|css)",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "max-age=31536000"
          }
        ]
      }
    ],
    "rewrites": [
      {
        "source": "/editor",
        "destination": "/editor.html"
      },
      {
        "source": "/ad/**",
        "destination": "/index.html"
      },
      {
        "source": "/fonts/**",
        "destination": "/editor.html"
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  }
}